# Django
SECRET_KEY=<run: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())">
DEBUG=False
ALLOWED_HOSTS=forcerare.ca,www.forcerare.ca

# MySQL
USE_MYSQL=True
DB_NAME=forcerare
DB_USER=forcerare
DB_PASSWORD=<strong-random-password>
DB_HOST=db
DB_PORT=3306
MYSQL_DATABASE=forcerare
MYSQL_USER=forcerare
MYSQL_PASSWORD=<same-as-DB_PASSWORD>
MYSQL_ROOT_PASSWORD=<different-strong-password>

# Linode Object Storage
USE_SPACES=True
SPACES_ACCESS_KEY=<linode-object-storage-access-key>
SPACES_SECRET_KEY=<linode-object-storage-secret-key>
SPACES_BUCKET_NAME=forcerare-media
SPACES_ENDPOINT_URL=https://us-ord-10.linodeobjects.com
SPACES_CDN_DOMAIN=forcerare-media.us-ord-10.linodeobjects.com

# Email (Cloudflare Email Routing forwards to Gmail, send via Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=faq.forcerare@gmail.com
EMAIL_HOST_PASSWORD=<gmail-app-password>
DEFAULT_FROM_EMAIL=faq.forcerare@gmail.com
CONTACT_EMAIL=contact@forcerare.ca

# CORS
CORS_ALLOWED_ORIGINS=https://forcerare.ca,https://www.forcerare.ca

# CSRF
CSRF_TRUSTED_ORIGINS=https://forcerare.ca,https://www.forcerare.ca
